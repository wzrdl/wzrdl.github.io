#!/usr/bin/env sh
set -eu

should_dispatch=0

while read -r local_ref local_oid remote_ref remote_oid; do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    should_dispatch=1
  fi
done

if [ "$should_dispatch" -ne 1 ]; then
  exit 0
fi

credentials="$(printf 'protocol=https\nhost=github.com\n\n' | git credential fill)"
token="$(printf '%s\n' "$credentials" | sed -n 's/^password=//p' | head -n 1)"

if [ -z "$token" ]; then
  echo "post-push: no GitHub token found in git credential store; deploy workflow was not dispatched" >&2
  exit 0
fi

status="$(
  curl -sS -o /dev/null -w '%{http_code}' \
    -X POST \
    -H "Authorization: Bearer $token" \
    -H "Accept: application/vnd.github+json" \
    -H "X-GitHub-Api-Version: 2022-11-28" \
    -H "Content-Type: application/json" \
    https://api.github.com/repos/wzrdl/wzrdl.github.io/actions/workflows/deploy.yml/dispatches \
    -d '{"ref":"main"}'
)"

if [ "$status" = "204" ]; then
  echo "post-push: dispatched Deploy site workflow for main"
else
  echo "post-push: failed to dispatch Deploy site workflow, HTTP $status" >&2
fi
